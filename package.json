{
  "name": "@domoskanonos/nidoca-core",
  "version": "1.0.657",
  "license": "MIT",
  "description": "nidoca framework (nidoca-core)",
  "files": [
    "lib/**/*"
  ],
  "main": "lib/index.js",
  "module": "./src/index.js",
  "devDependencies": {
    "@domoskanonos/nidoca-webpack": "1.0.5"  },
  "dependencies": {
    "lit-element": "^2.4.0"
  },
  "author": "Dominik Bruhn",
  "scripts": {
    "start": "webpack serve --config webpack.local.js",
    "ts": "tsc",
    "ts:watch": "tsc --watch",
    "pretty": "prettier --write \"./**/*.{ts,json}\"",
    "eslint": "eslint src",
    "eslint:fix": "eslint src --fix",
    "test": "wtr",
    "test:watch": "npm run test -- --watch",
    "build:webcomponent": "npm install && npm run ts && webpack --config ./webpack.prod.js ",
    "preversion": "",
    "new-patch": "npm version patch -m \"new patch version: %s\" --force",
    "new-minor": "npm version minor -m \"new minor version: %s\" --force",
    "new-major": "npm version major -m \"new major version: %s\" --force",
    "postversion": "npm publish --access=public"
  },
  "browserslist": [
    "last 1 Chrome version"
  ]
}
