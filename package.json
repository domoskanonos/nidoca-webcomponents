{
  "name": "@domoskanonos/nidoca-core",
  "version": "1.0.652",
  "license": "MIT",
  "description": "nidoca framework (nidoca-core)",
  "files": [
    "lib/**/*"
  ],
  "main": "lib/index.js",
  "module": "./source/index.js",
  "devDependencies": {
    "prettier": "^2.2.1",
    "typescript": "^4.1.5",
    "ts-loader": "8.0.17",
    "html-webpack-plugin": "5.3.1",
    "terser-webpack-plugin": "5.1.1",
    "webpack": "5.28.0",
    "webpack-cli": "^3.3.12",
    "webpack-dev-server": "3.11.2"
  },
  "dependencies": {
    "lit-element": "^2.4.0"
  },
  "author": "Dominik Bruhn",
  "scripts": {
    "start": "webpack-dev-server --config webpack.dev.js --open",
    "build_ts": "tsc -p ./",
    "pretty": "prettier --write \"./**/*.{ts,json}\"",
    "new-version": "npm run build_ts && npm version patch && npm publish --access=public",
    "unpublish": "npm unpublish --force"
  },
  "browserslist": [
    "last 1 Chrome version"
  ]
}
