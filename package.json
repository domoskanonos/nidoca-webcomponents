{
  "name": "@domoskanonos/nidoca-webcomponents",
  "version": "1.0.18",
  "license": "MIT",
  "keywords": [
    "webcomponent, html, typescript, shadow dom, slot, ui, frontend, lit element"
  ],
  "description": "nidoca framework (nidoca-core)",
  "files": [
    "lib/**/*"
  ],
  "main": "lib/index.js",
  "module": "./src/index.js",
  "devDependencies": {
    "@domoskanonos/nidoca-router": "1.0.2",
    "@domoskanonos/nidoca-webpack": "1.0.6"
  },
  "dependencies": {
    "lit": "2.0.0-rc.2"
  },
  "author": "Dominik Bruhn",
  "scripts": {
    "start": "webpack serve --config webpack.dev.js",
    "ts": "tsc",
    "ts:watch": "tsc --watch",
    "pretty": "prettier --write \"./**/*.{ts,json}\"",
    "eslint": "eslint src",
    "eslint:fix": "eslint src --fix",
    "lit-analyzer": "lit-analyzer \"src/**/*.{js,ts}\"",
    "test": "wtr",
    "test:watch": "npm run test -- --watch",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "build:webcomponent": "npm install && npm run ts && npm run lit-analyzer && npm run docs && webpack --config ./webpack.webcomponent.js",
    "preversion": "npm run build:webcomponent",
    "new-patch": "npm version patch -m \"new patch version: %s\" --force",
    "new-minor": "npm version minor -m \"new minor version: %s\" --force",
    "new-major": "npm version major -m \"new major version: %s\" --force",
    "postversion": "npm publish --access=public"
  },
  "browserslist": [
    "last 1 Chrome version"
  ]
}
