{
  "name": "@domoskanonos/nidoca-showcase",
  "version": "1.0.0",
  "license": "MIT",
  "description": "nidoca framework (nidoca-showcase)",
  "devDependencies": {
    "parcel-bundler": "^1.12.4",
    "prettier": "^2.2.1",
    "prettier-plugin-organize-imports": "^1.1.1",
    "typescript": "^4.1.4"
  },
  "dependencies": {
    "@domoskanonos/nidoca-core": "latest"
  },
  "author": "Dominik Bruhn",
  "scripts": {
    "pretty": "prettier --write \"./**/*.{ts,json}\"",
    "build_ts": "npm run pretty & tsc -p ./",
    "build": "npm run pretty & parcel build source/index.html -d build/output --no-content-hash --no-source-maps --public-url ./",
    "start": "parcel source/index.html",
    "new-version": "npm run build & npm version patch & npm publish --access=public",
    "unpublish": "npm unpublish --force"
  },
  "browserslist": [
    "last 1 Chrome version"
  ]
}
