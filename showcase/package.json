{
  "name": "@domoskanonos/nidoca-showcase",
  "version": "1.0.0",
  "license": "MIT",
  "description": "nidoca framework (nidoca-showcase)",
  "devDependencies": {
    "html-webpack-plugin": "^3.2.0",
    "prettier": "^2.2.1",
    "prettier-plugin-organize-imports": "^1.1.1",
    "terser-webpack-plugin": "^2.3.8",
    "ts-loader": "8.0.17",
    "typescript": "^4.1.4",
    "webpack": "^4.41.6",
    "webpack-cli": "^3.3.11",
    "webpack-dev-server": "3.11.2"
  },
  "dependencies": {
    "@domoskanonos/frontend-basis": "^1.0.239",
    "@domoskanonos/nidoca-core": "^1.0.616"
  },
  "author": "Dominik Bruhn",
  "scripts": {
    "start": "webpack-dev-server --config webpack.dev.js --open",
    "pretty": "prettier --write \"./**/*.{ts,json}\"",
    "build": "cd .. && cd generator && npm install && npm run generate-showcase && cd.. && cd showcase && npm install && npm run pretty && tsc -p ./",
    "bundle": "npm run build && webpack"
  },
  "browserslist": [
    "last 1 Chrome version"
  ]
}
