{
  "name": "@domoskanonos/nidoca-core",
  "version": "1.0.557",
  "license": "MIT",
  "description": "nidoca framework (nidoca-core)",
  "files": [
    "lib/**/*"
  ],
  "main": "lib/index.js",
  "module": "./source/index.js",
  "devDependencies": {
    "parcel-bundler": "^1.12.4",
    "prettier": "^2.2.1",
    "typescript": "^4.1.4"
  },
  "dependencies": {
    "lit-element": "^2.4.0"
  },
  "author": "Dominik Bruhn",
  "scripts": {
    "start": "parcel source/index.html",
    "build_ts": "tsc -p ./",
    "build": "parcel build source/index.html -d build/output --no-content-hash --no-source-maps --public-url ./",
    "pretty": "prettier --write \"./**/*.{ts,json}\"",
    "new-version": "npm run build_ts & npm version patch & git add . & git commit -m \"new version\" & git push & npm publish --access=public",
    "unpublish": "npm unpublish --force"
  },
  "browserslist": [
    "last 1 Chrome version"
  ]
}
